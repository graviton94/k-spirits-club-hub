# Queries for the App

query listSpirits($category: String, $subcategory: String, $country: String) @auth(level: PUBLIC) {
  spirits(where: { 
    isPublished: { eq: true },
    category: { eq: $category },
    subcategory: { eq: $subcategory },
    country: { eq: $country }
  }) {
    id
    name
    nameEn
    category
    categoryEn
    imageUrl
    thumbnailUrl
    isPublished
    abv
    distillery
    rating
    reviewCount
  }
}

query searchSpiritsPublic(
  $search: String,
  $category: String,
  $subcategory: String,
  $limit: Int,
  $offset: Int
) @auth(level: PUBLIC) {
  spirits(
    limit: $limit,
    offset: $offset,
    orderBy: [{ updatedAt: DESC }],
    where: {
      _and: [
        { isPublished: { eq: true } },
        { category: { eq: $category } },
        { subcategory: { eq: $subcategory } },
        { 
          _or: [
            { name: { contains: $search } },
            { nameEn: { contains: $search } },
            { distillery: { contains: $search } }
          ]
        }
      ]
    }
  ) {
    id
    name
    nameEn
    category
    categoryEn
    subcategory
    imageUrl
    thumbnailUrl
    abv
    distillery
    rating
    reviewCount
    metadata
  }
}

query listAllCategories @auth(level: PUBLIC) {
