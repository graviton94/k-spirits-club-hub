<file path="dataconnect/schema/schema.gql">
# K-Spirits Club Hub - SQL Schema (PostgreSQL)

type User @table {
  id: String!
  email: String
  nickname: String @col(dataType: "varchar(100)")
  profileImage: String
  role: String @col(dataType: "varchar(20)") @default(value: "USER")
  themePreference: String @col(dataType: "varchar(10)") @default(value: "light")
  isFirstLogin: Boolean @default(value: true)
  reviewsWritten: Int @default(value: 0)
  heartsReceived: Int @default(value: 0)
  tasteProfile: Any
  createdAt: Timestamp @default(expr: "request.time")
}

type Spirit @table {
  id: String!
  name: String!
  nameEn: String
  category: String!
  categoryEn: String
  mainCategory: String
  subcategory: String
  distillery: String
  bottler: String
  abv: Float
  volume: Int
  country: String
  region: String
  imageUrl: String!
  thumbnailUrl: String
  descriptionKo: String
  descriptionEn: String
  pairingGuideKo: String
  pairingGuideEn: String
  noseTags: [String!]
  palateTags: [String!]
  finishTags: [String!]
  tastingNote: String
  status: String @col(dataType: "varchar(50)")
  importer: String @col(dataType: "varchar(200)")
  rawCategory: String @col(dataType: "varchar(200)")
  isPublished: Boolean @default(value: false)
  isReviewed: Boolean @default(value: false)
  reviewedBy: String
  reviewedAt: Timestamp
  rating: Float @default(value: 0.0)
  reviewCount: Int @default(value: 0)
  metadata: Any
  createdAt: Timestamp! @default(expr: "request.time")
  updatedAt: Timestamp! @default(expr: "request.time")
}

# --- Home Curation ---
type NewArrival @table {
  id: String!
  spirit: Spirit!
  displayOrder: Int @default(value: 0)
  tags: [String!]
  createdAt: Timestamp @default(expr: "request.time")
}

type SpiritReview @table {
  id: UUID! @default(expr: "uuidV4()")
  spirit: Spirit!
  user: User!
  rating: Int!
  title: String
  content: String!
  nose: String
  palate: String
  finish: String
  likes: Int @default(value: 0)
  isPublished: Boolean @default(value: true)
  imageUrls: [String!]
  createdAt: Timestamp! @default(expr: "request.time")
  updatedAt: Timestamp! @default(expr: "request.time")
}

# --- Social Interaction ---
type ReviewLike @table(key: ["user", "review"]) {
  user: User!
  review: SpiritReview!
  createdAt: Timestamp @default(expr: "request.time")
}

type ReviewComment @table {
  id: UUID! @default(expr: "uuidV4()")
  review: SpiritReview!
  user: User!
  content: String @col(dataType: "varchar(500)")
  createdAt: Timestamp @default(expr: "request.time")
  updatedAt: Timestamp @default(expr: "request.time")
}

type NewsArticle @table {
  id: String!
  title: String!
  content: String!
  imageUrl: String
  category: String
  source: String
  link: String
  date: String @index
  translations: Any
  tags: Any
  createdAt: Timestamp @default(expr: "request.time") @index
  updatedAt: Timestamp @default(expr: "request.time")
}

type UserCabinet @table(key: ["user", "spirit"]) {
  user: User!
  spirit: Spirit!
  addedAt: Timestamp @default(expr: "request.time")
  notes: String
  rating: Int
  isFavorite: Boolean @default(value: false)
  isWishlist: Boolean @default(value: false)
}

type ModificationRequest @table {
  id: String!
  spiritId: String!
  spiritName: String
  userId: String
  title: String!
  content: String!
  status: String @default(value: "pending")
  createdAt: Timestamp @default(expr: "request.time")
}

type WorldCupResult @table {
  id: UUID! @default(expr: "uuidV4()")
  winner: Spirit!
  category: String!
  subcategory: String
  initialRound: Int
  timestamp: Timestamp @default(expr: "request.time")
}

type AiDiscoveryLog @table {
  id: String!
  userId: String
  analysis: String
  recommendations: Any # Array of {name, inDb}
  messageHistory: Any # Array of {role, content}
  createdAt: Timestamp @default(expr: "request.time")
}
</file>

